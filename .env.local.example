# Copy to .env.local (gitignored) and fill in values.
# Restart Expo and the feature runner after changes.

# App + runner auth (must match)
EXPO_PUBLIC_FEATURE_SPRINT_RUNNER_TOKEN=life-harness-local-dev
FEATURE_SPRINT_RUNNER_TOKEN=life-harness-local-dev

# Real mode — enables Codex scoping/review/audit + Cursor/Codex implementation
FEATURE_SPRINT_RUNNER_MODE=real
FEATURE_SPRINT_RUNNER_ENABLE_CODEX=1
FEATURE_SPRINT_RUNNER_ENABLE_CURSOR=1
FEATURE_SPRINT_RUNNER_ENABLE_IMPLEMENTATION=1

# Required for cursor_* profiles (Cursor dashboard → Integrations → User API Keys)
CURSOR_API_KEY=

# Optional: auto | composer-2.5 | etc.
FEATURE_SPRINT_CURSOR_MODEL=auto
