{
  "name": "life-harness",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "npx concurrently -k -n launcher,expo \"npm run scout:launcher\" \"expo start --web\"",
    "scout:launcher": "tsx scripts/job-scout-launcher.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run check:agent-budget && npm run check:boundaries && npm run verify:app && npm run verify:job-scout",
    "verify:app": "npm run typecheck && npm run test",
    "verify:core": "vitest run src/core",
    "verify:job-scout": "npm run scout:runner:test",
    "check:boundaries": "tsx scripts/check-boundaries.ts",
    "check:agent-budget": "tsx scripts/check-agent-budget.ts",
    "agent:bootstrap": "tsx scripts/agent-bootstrap.ts",
    "agent:map": "tsx scripts/agent-map.ts",
    "agent:grep": "tsx scripts/agent-grep.ts",
    "agent:symbols": "tsx scripts/agent-symbols.ts",
    "agent:exports": "tsx scripts/agent-exports.ts",
    "agent:tests-for": "tsx scripts/agent-tests-for.ts",
    "agent:impact": "tsx scripts/agent-impact.ts",
    "agent:test": "tsx scripts/agent-test.ts",
    "agent:typecheck": "tsx scripts/agent-typecheck.ts",
    "agent:verify": "tsx scripts/agent-verify.ts",
    "agent:failures": "tsx scripts/agent-failures.ts",
    "agent:review-packet": "tsx scripts/agent-review-packet.ts",
    "scout:runner": "tsx services/job-scout-runner/src/server.ts",
    "scout:runner:test": "vitest run services/job-scout-runner/tests",
    "feature-runner": "tsx services/feature-sprint-runner/src/server.ts",
    "feature-runner:mock": "tsx services/feature-sprint-runner/scripts/startMockRunner.ts",
    "feature-runner:cursor": "tsx services/feature-sprint-runner/scripts/startCursorRunner.ts",
    "feature-runner:setup-check": "tsx services/feature-sprint-runner/scripts/setupCheck.ts",
    "feature-runner:test": "vitest run services/feature-sprint-runner/tests",
    "resume:build": "tsx scripts/build-resume-docx.ts",
    "resume:build:application": "tsx scripts/build-application-resume-docx.ts",
    "career:pack:build": "tsx scripts/build-career-source-pack.ts",
    "career:pack:build:local": "tsx scripts/build-career-source-pack.ts -- --source private/career-source --out resume_pack/life_harness_career_pack.v1.json",
    "career:pack:validate:local": "tsx scripts/validate-career-source-pack.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "docx": "^9.7.1",
    "expo": "56.0.9",
    "expo-constants": "~56.0.17",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "jszip": "^3.10.1",
    "tsx": "^4.20.5",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  }
}
