# Mock mode — no secrets required.
# Usage: npm run feature-runner:mock
# Or: .\services\feature-sprint-runner\scripts\start-mock-runner.ps1

FEATURE_SPRINT_RUNNER_MODE=mock
FEATURE_SPRINT_RUNNER_TOKEN=life-harness-dev

# --- Real Cursor mode (copy block below into .env.local instead) ---
# CURSOR_API_KEY=your_user_api_key_here
# FEATURE_SPRINT_RUNNER_MODE=cursor
# FEATURE_SPRINT_RUNNER_ENABLE_CURSOR=1
# FEATURE_SPRINT_RUNNER_ENABLE_IMPLEMENTATION=1
# FEATURE_SPRINT_RUNNER_TOKEN=life-harness-dev
# FEATURE_SPRINT_CURSOR_MODEL=auto
#
# Pair with app .env:
# EXPO_PUBLIC_FEATURE_SPRINT_RUNNER_TOKEN=life-harness-dev

# --- Real Codex / mixed mode ---
# FEATURE_SPRINT_RUNNER_MODE=real
# FEATURE_SPRINT_RUNNER_ENABLE_CODEX=1
# FEATURE_SPRINT_RUNNER_ENABLE_CURSOR=1
# FEATURE_SPRINT_RUNNER_ENABLE_IMPLEMENTATION=1
# FEATURE_SPRINT_RUNNER_TOKEN=life-harness-dev
# FEATURE_SPRINT_CODEX_BIN=C:\Users\YOU\AppData\Roaming\npm\codex.cmd
# CURSOR_API_KEY=your_user_api_key_here
